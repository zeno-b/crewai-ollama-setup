# Copy to .env and adjust. Never commit real secrets.

ENVIRONMENT=development

# API (see config/settings.py for full list)
API_TITLE=CrewAI Service
API_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
CREWAI_PORT=8000

# Ollama (in Docker Compose use service hostname)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2:7b
OLLAMA_TIMEOUT=300

# Redis (optional password; if set, use redis://redis:6379 and REDIS_PASSWORD)
REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=

# Security — required in production for stable sessions across restarts
SECRET_KEY=replace-with-openssl-rand-base64-32-or-longer
# Optional: protect mutating HTTP routes (POST /datasets, DELETE, /retraining/jobs, /create_agent, /run_crew)
# API_BEARER_TOKEN=
# Optional: require same style bearer for GET /metrics
# METRICS_BEARER_TOKEN=

# CORS: comma-separated origins, or * for allow-all (disallowed when ENVIRONMENT=production)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Data paths (override for portable volumes)
DATASET_DIR=data/datasets
RETRAINING_DIR=data/retraining
DATASET_MAX_CONTENT_BYTES=5242880
MODELFILE_TEMPLATE_DIR=config/modelfiles

# JWT-style settings (reserved for future auth)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Monitoring
METRICS_ENABLED=true
