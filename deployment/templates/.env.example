# -----------------------------------------------------------------------------
# CrewAI & Ollama Deployment Environment Template
# -----------------------------------------------------------------------------

# Application environment
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Logging & Monitoring
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=9090

# Ollama connectivity
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2:latest
OLLAMA_TIMEOUT=300

# Redis cache
REDIS_URL=redis://redis:6379
REDIS_DB=0

# Security (values will be generated during deployment)
SECRET_KEY={{SECRET_KEY}}
JWT_SECRET={{JWT_SECRET}}

# Grafana bootstrap
GRAFANA_PASSWORD={{GRAFANA_PASSWORD}}

# -----------------------------------------------------------------------------
